# ============================================================
# AI Deploy Agent v2 — Local Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Full URL to ai-deploy.php on your hosting
DEPLOY_URL=https://example.com/_deploy/ai-deploy.php

# Secret token — must match DEPLOY_SECRET in ai-deploy.php
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DEPLOY_TOKEN=change_me_to_a_strong_random_token

# Local directory to package and deploy (relative or absolute)
SOURCE_DIR=../dist

# Temporary ZIP filename (created locally, deleted after upload)
ZIP_NAME=site-deploy.zip

# Maximum upload size in MB (must not exceed server PHP limit)
MAX_UPLOAD_MB=64

# Project label shown in local logs and /status output
# Updated automatically by /set-target
DEPLOY_LABEL=my-website

# ── Multi-project tip ──────────────────────────────────────────
# For multiple projects, maintain separate files:
#   .env.zakinfo
#   .env.bakery-site
# Copy the relevant one to .env before deploying, or use:
#   deploy.bat /set-target "zakinfo"
